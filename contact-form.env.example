# Скопируйте в .env на сервере или задайте в панели хостинга.
# Письма с формы «Контакты» уходят на CONTACT_MAIL_TO (по умолчанию info@re-spo.com).

# --- Почта (Яндекс / Yandex 360 для домена) ---
# В аккаунте Яндекс: включите SMTP, при необходимости создайте «пароль приложения».
CONTACT_SMTP_HOST=smtp.yandex.ru
CONTACT_SMTP_PORT=465
# CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=robot@re-spo.com
CONTACT_SMTP_PASS=ваш_пароль_или_пароль_приложения

# Куда слать заявки (ящик INFO@RE-SPO.COM — тот же адрес, регистр не важен)
CONTACT_MAIL_TO=info@re-spo.com

# --- Yandex SmartCaptcha (Облако) — опционально, но рекомендуется ---
# Клиентский ключ вставьте в HTML: атрибут data-yandex-smartcaptcha-sitekey на <form id="contact-form">
# либо попросите разработчика подставить из шаблона.
YANDEX_SMARTCAPTCHA_SECRET=секретный_ключ_сервера_из_консоли_облака

# --- За reverse-proxy (nginx) для корректного IP в SmartCaptcha ---
# TRUST_PROXY=1
