{
  "name": "RE-SPO-web",
  "version": "1.0.0",
  "description": "RE-SPO — Reliable Experts, Successful Plant Operation",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:server": "node server.js",
    "dev": "concurrently \"npm:dev:server\" \"npm:watch:css\"",
    "build:css": "tailwindcss -c tailwind.config.js -i ./css/style.css -o ./css/tailwind.css --minify",
    "watch:css": "tailwindcss -c tailwind.config.js -i ./css/style.css -o ./css/tailwind.css --watch"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.21.2",
    "nodemailer": "^6.9.16",
    "helmet": "^8.0.0",
    "multer": "^2.1.1",
    "ssh2": "^1.17.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19"
  }
}
